<div id="starfield-container"></div>
<script>
  function initStarfield() {
    const container = document.getElementById('starfield-container');
    if (!container) return;

    function generateStars() {
      container.innerHTML = ''; // Clear out existing stars
      for (let i = 0; i < 600; i++) {
        let span = document.createElement("span");
        let starSize = Math.random() > 0.5 ? "3px" : "2px";
        
        span.style.setProperty("--random", Math.random().toString());
        span.style.width = "2px";
        span.style.height = starSize;
        span.style.position = "absolute";
        span.style.backgroundColor = "white";
        span.style.opacity = Math.min(Math.random() + 0.25, 1).toString();
        span.style.left = Math.random() * window.innerWidth + "px";
        span.style.top = Math.random() * window.innerHeight + "px";
        span.style.transform = "rotate(" + Math.random() * 360 + "deg)";
        span.className = "twinkle";
        
        container.appendChild(span);
      }
    }
    
    // Initial generation
    generateStars();

    // Redraw stars on resize to maintain density and fill space
    let resizeTimer;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(generateStars, 200);
    });
  }
  
  // Astro view transitions or standard load
  document.addEventListener('DOMContentLoaded', initStarfield);
</script>

<style>
  #starfield-container {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: fixed;
    top: 0;
    left: 0;
    z-index: -2;
    pointer-events: none;
  }
</style>
