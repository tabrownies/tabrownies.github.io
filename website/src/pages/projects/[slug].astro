---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projectsEntries = await getCollection('projects');
  return projectsEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<MainLayout>
  <div class="reading-column">
    <div class="post-header">
      <h1 class="text-orange">{entry.data.title}</h1>
      <div class="post-meta line-mono">
        <span>{new Date(entry.data.date).toLocaleDateString()}</span>
        <span>|</span>
        <span>{entry.data.category}</span>
      </div>
      {entry.data.tags && entry.data.tags.length > 0 && (
        <div class="post-tags">
          {entry.data.tags.map(tag => (
            <span class="tag tag-orange">{tag}</span>
          ))}
        </div>
      )}
    </div>
    
    <article class="markdown-wrapper theme-projects">
      <Content />
    </article>
  </div>
</MainLayout>

<style>
  .reading-column {
    max-width: 800px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem 1.5rem;
    min-height: 100vh;
  }
  .post-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid #333;
    padding-bottom: 2rem;
  }
  .post-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--pillar2-accent);
  }
  .post-meta {
    color: #888;
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .line-mono {
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid currentColor;
    border-radius: 1px;
  }
  .tag-orange {
    color: var(--pillar2-accent);
    background: rgba(255, 127, 67, 0.1);
  }
  
  /* Markdown styling overrides */
  .markdown-wrapper :global(h1), 
  .markdown-wrapper :global(h2), 
  .markdown-wrapper :global(h3), 
  .markdown-wrapper :global(h4) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: white;
  }
  
  .markdown-wrapper :global(p) {
    margin-bottom: 1.5rem;
    color: #f5f5f5;
  }
  
  .markdown-wrapper :global(a) {
    color: var(--pillar2-accent);
    text-decoration: none;
    border-bottom: 1px dashed var(--pillar2-accent);
  }
  .markdown-wrapper :global(a:hover) {
    border-bottom-style: solid;
  }
  
  .markdown-wrapper :global(ul), 
  .markdown-wrapper :global(ol) {
    margin-left: 1.5rem;
    margin-bottom: 1.5rem;
  }
  
  .markdown-wrapper :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .markdown-wrapper :global(pre) {
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid #333;
  }
  
  .markdown-wrapper :global(blockquote) {
    border-left: 4px solid var(--pillar2-accent);
    padding-left: 1rem;
    margin-left: 0;
    color: #aaa;
    font-style: italic;
  }
</style>
